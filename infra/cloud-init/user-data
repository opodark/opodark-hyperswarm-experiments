#cloud-config

hostname: hyperswarm-node

users:
  - name: swarm
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash

package_update: true
package_upgrade: true

packages:
  - curl
  - git
  - python3
  - python3-pip
  - docker.io
  - jq

write_files:

  - path: /opt/hyperswarm/config.json
    content: |
      {
        "role": "auto",
        "status": "booting"
      }

runcmd:

  # ─────────────────────────────
  # 1. INSTALL OLLAMA
  # ─────────────────────────────

  - curl -fsSL https://ollama.com/install.sh | sh

  - systemctl enable ollama
  - systemctl start ollama

  - sleep 10

  # ─────────────────────────────
  # 2. LOAD BASE MODEL (BOOTSTRAP)
  # ─────────────────────────────

  - ollama pull phi3:mini

  # ─────────────────────────────
  # 3. INSTALL SWARM AGENT
  # ─────────────────────────────

  - mkdir -p /opt/hyperswarm
  - git clone https://github.com/opodark/hyperswarm.git /opt/hyperswarm

  - pip3 install fastapi uvicorn requests pydantic

  # ─────────────────────────────
  # 4. REGISTER NODE
  # ─────────────────────────────

  - python3 /opt/hyperswarm/bootstrap/client/bootstrap.py

  # ─────────────────────────────
  # 5. START AGENT SERVICE
  # ─────────────────────────────

  - nohup python3 /opt/hyperswarm/agent/runtime.py &